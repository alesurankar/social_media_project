# Base URL of backend API for mobile devices
# Replace <YOUR_LOCAL_IP> with the IP of the machine running the server
API_URL=http://<YOUR_LOCAL_IP>:4000/api/v1


# 1. to find local ip in terminal run "ipconfig"
# 2. look for IPv4 Address
# 3. ⚠️ Rename this file from "example.env.local" to ".env.local"